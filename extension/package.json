{
  "name": "llmb-rts-notebook",
  "displayName": "llmb RTS Notebook",
  "description": "Operator interface for supervising fleets of autonomous coding agents. Subtractive fork of vscode-jupyter; renders .llmnb notebooks backed by LLMKernel as MCP/PTY mediator.",
  "version": "0.1.0",
  "publisher": "ethycs",
  "license": "GPL-3.0-only",
  "engines": {
    "vscode": "^1.92.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Notebooks",
    "AI",
    "Other"
  ],
  "keywords": [
    "llm",
    "agents",
    "mcp",
    "notebook",
    "rts"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onNotebook:llmnb"
  ],
  "contributes": {
    "notebooks": [
      {
        "type": "llmnb",
        "displayName": "llmb RTS Notebook",
        "selector": [
          {
            "filenamePattern": "*.llmnb"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "llmnb-cell",
        "aliases": [
          "llmb cell"
        ],
        "extensions": [
          ".llmnb-cell"
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "llmnb-run-renderer",
        "displayName": "LLMNB Run Renderer",
        "entrypoint": "./dist/run-renderer.js",
        "mimeTypes": [
          "application/vnd.rts.run+json"
        ]
      }
    ],
    "commands": [
      {
        "command": "llmnb.spawn",
        "title": "LLMNB: Spawn agent (TODO C2: wire in R2)",
        "category": "LLMNB"
      },
      {
        "command": "llmnb.attach",
        "title": "LLMNB: Attach to agent (TODO C2: wire in R2)",
        "category": "LLMNB"
      },
      {
        "command": "llmnb.openMapView",
        "title": "LLMNB: Open map view",
        "category": "LLMNB"
      },
      {
        "command": "llmnb.showKernelTerminal",
        "title": "LLMNB: Show kernel terminal",
        "category": "LLMNB"
      }
    ],
    "configuration": {
      "title": "LLMNB",
      "properties": {
        "llmnb.kernel.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter used to spawn LLMKernel via `python -m llm_kernel pty-mode` (RFC-008 §3)."
        },
        "llmnb.kernel.useStub": {
          "type": "boolean",
          "default": false,
          "description": "Use the in-process stub kernel client (debug only)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:node-pty --format=cjs --platform=node --minify",
    "package:renderer": "esbuild src/renderers/run-renderer.ts --bundle --outfile=dist/run-renderer.js --format=esm --platform=browser --minify",
    "lint": "eslint src --ext ts",
    "build:tests": "tsc -p ./tsconfig.test.json",
    "pretest:unit": "npm run build:tests",
    "test:unit": "mocha --config .mocharc-unit.cjs",
    "pretest:stub": "npm run build:tests && npm run package && npm run package:renderer",
    "test:stub": "vscode-test --config .vscode-test-stub.mjs",
    "pretest:live": "npm run build:tests && npm run package && npm run package:renderer",
    "test:live": "vscode-test --config .vscode-test-live.mjs",
    "test:contract": "npm run test:unit && npm run test:stub",
    "pretest:e2e": "npm run build && npm run package",
    "test:e2e": "wdio run ./wdio.conf.ts",
    "test": "vscode-test",
    "pretest": "npm run build && npm run lint"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "@types/vscode-notebook-renderer": "^1.72.0",
    "wdio-vscode-service": "^6.1.0"
  }
}
